# ==========================================
# freee キャッシュフロー予測ダッシュボード 環境設定
# このファイルを .env にコピーして編集してください
# ==========================================

# Mockモード（true: freee APIを呼ばずダミーデータで動作 / false: 実データ）
# 初回は true で動作確認することを推奨いたします
MOCK_MODE=true

# freee Developersで取得した認証情報
# https://app.secure.freee.co.jp/developers/applications
FREEE_CLIENT_ID=
FREEE_CLIENT_SECRET=
FREEE_REDIRECT_URI=http://localhost:8765/oauth/callback

# トークン暗号化用キー（32文字以上のランダム文字列）
# 生成例: python -c "import secrets; print(secrets.token_hex(32))"
# 一度設定したら変更しないでください（変更すると保存済みトークンが復号できなくなります）
APP_SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long

# 起動ポート
APP_PORT=8765
